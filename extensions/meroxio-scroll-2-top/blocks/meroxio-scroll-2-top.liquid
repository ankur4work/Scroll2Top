<style>
  /* Default Scroll to Top Button Styling */
  #scrollTopBtn {
    position: fixed;
    bottom: -50px; /* Start off-screen */
    right: 20px;
    background-color: #28A745; /* Default (free plan) */
    color: white;
    border: none;
    padding: 11px 15px;
    font-size: 20px;
    cursor: pointer;
    box-shadow: 0 8px 15px rgba(0, 0, 0, 0.2);
    opacity: 0;
    visibility: hidden;
    transition: bottom 0.4s ease, opacity 0.4s ease, visibility 0.4s ease;
    border-radius: 50%;
    display: none; /* Hidden by default */
    z-index: 9999;
  }

  #scrollTopBtn:hover {
    background-color: #1C7530;
  }

  #scrollTopBtn.show {
    bottom: 20px;
    opacity: 1;
    visibility: visible;
  }
</style>

<!-- Scroll Button -->
<button id="scrollTopBtn" onclick="scrollToTop()" style="background: {{ block.settings.bgcolor }};">
  {% case block.settings.icon_style %}
    {% when 'chevron' %}
      <!-- Chevron Up -->
      <svg height="30px" width="30px"
        xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16">
        <polygon fill="white" points="3.5 10.8 8 6.3 12.5 10.8 11.3 12 8 8.7 4.7 12" />
      </svg>

    {% when 'arrow' %}
      <!-- Arrow Up with stem -->
      <svg height="30px" width="30px"
        xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16">
        <polygon fill="white" points="8 3 3 9 6 9 6 13 10 13 10 9 13 9" />
      </svg>

    {% when 'triangle' %}
      <!-- Solid triangle arrow -->
      <svg height="30px" width="30px"
        xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16">
        <polygon fill="white" points="8 4 3 11 13 11" />
      </svg>

    {% when 'double_chevron' %}
      <!-- Double Chevron Up -->
      <svg height="30px" width="30px"
        xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16">
        <polygon fill="white" points="3.5 11 8 6.5 12.5 11 11.4 12.1 8 8.7 4.6 12.1" />
        <polygon fill="white" points="3.5 8.5 8 4 12.5 8.5 11.4 9.6 8 6.2 4.6 9.6" />
      </svg>

    {% when 'circle_arrow' %}
      <!-- Arrow inside a circle -->
      <svg height="30px" width="30px"
        xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="11" fill="none" stroke="white" stroke-width="1.5" />
        <polygon fill="white" points="12 7 7 13 10 13 10 17 14 17 14 13 17 13" />
      </svg>

    {% when 'minimal' %}
      <!-- Minimal thin caret up -->
      <svg height="30px" width="30px"
        xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16">
        <polygon fill="white" points="4.5 11 8 7.5 11.5 11 10.8 11.7 8 8.9 5.2 11.7" />
      </svg>

    {% else %}
      <!-- Default icon (fallback) -->
      <svg height="30px" width="30px"
        xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16">
        <polygon fill="white" points="8 4 3 10 6 10 6 12 10 12 10 10 13 10" />
      </svg>
  {% endcase %}
</button>

<script>
document.addEventListener('DOMContentLoaded', async () => {
  const scrollBtn = document.querySelector("#scrollTopBtn");
  const scrollSvg = scrollBtn.querySelector("svg");
  let plan = "free";

  try {
    const shopUrl = "{{ shop.url }}";
    const shop = shopUrl.replace(/^https?:\/\//, "");
    const res = await fetch(`/apps/scroll-to-top/hasSubscription?shop=${shop}`, {
      method: "GET",
      headers: { "Content-Type": "application/json" },
    });
    if (res.ok) {
      const data = await res.json();
      if (data && data.tier) plan = data.tier;
    }
  } catch (err) {
    console.warn("⚠️ Subscription check failed, defaulting to free:", err);
  }

  console.log("🎯 Final plan detected:", plan);

  /* ---------------- FREE PLAN ---------------- */
  if (plan === "free") {
    // Free: homepage only, settings ignored
    {% if template contains 'index' %}
      scrollBtn.style.display = "block";
    {% else %}
      scrollBtn.style.display = "none";
    {% endif %}

    scrollSvg.style.fill = "#FFFFFF"; // fixed icon color
    scrollBtn.style.backgroundColor = "#28A745";
    scrollBtn.style.borderRadius = "50%";
  }

  /* ---------------- BASIC PLAN (backend: premium) ---------------- */
  else if (plan === "premium") {
    let show = false;

    // Basic plan: only "Show on Home Page" setting works
    {% if block.settings.show_on_home_page %}
      if ("{{ template }}" && "{{ template }}".includes("index")) show = true;
    {% endif %}

    scrollBtn.style.display = show ? "block" : "none";

    // Apply customization (color, hover, icon, position, shape)
    scrollBtn.style.backgroundColor = "{{ block.settings.bgcolor }}";
    scrollSvg.style.fill = "{{ block.settings.iconcolor }}";

    scrollBtn.addEventListener("mouseover", () => {
      scrollBtn.style.backgroundColor = "{{ block.settings.hovercolor }}";
    });
    scrollBtn.addEventListener("mouseout", () => {
      scrollBtn.style.backgroundColor = "{{ block.settings.bgcolor }}";
    });

    {% if block.settings.position == "left" %}
      scrollBtn.style.left = "20px";
      scrollBtn.style.right = "auto";
    {% else %}
      scrollBtn.style.right = "20px";
      scrollBtn.style.left = "auto";
    {% endif %}

    {% if block.settings.shape == "square" %}
      scrollBtn.style.borderRadius = "10px";
    {% else %}
      scrollBtn.style.borderRadius = "50%";
    {% endif %}
  }

  /* ---------------- PREMIUM PLAN (backend: unlimited) ---------------- */
  else if (plan === "unlimited") {
    let show = false;

    // Premium: all four visibility settings work
    {% if block.settings.show_on_home_page %}
      if ("{{ template }}" && "{{ template }}".includes("index")) show = true;
    {% endif %}
    {% if block.settings.show_on_product_page %}
      if ("{{ template }}" && "{{ template }}".includes("product")) show = true;
    {% endif %}
    {% if block.settings.show_on_collection_page %}
      if ("{{ template }}" && "{{ template }}".includes("collection")) show = true;
    {% endif %}
    {% if block.settings.show_on_pages %}
      if ("{{ template }}" && "{{ template }}".includes("page")) show = true;
    {% endif %}

    scrollBtn.style.display = show ? "block" : "none";

    // Apply customization
    scrollBtn.style.backgroundColor = "{{ block.settings.bgcolor }}";
    scrollSvg.style.fill = "{{ block.settings.iconcolor }}";

    scrollBtn.addEventListener("mouseover", () => {
      scrollBtn.style.backgroundColor = "{{ block.settings.hovercolor }}";
    });
    scrollBtn.addEventListener("mouseout", () => {
      scrollBtn.style.backgroundColor = "{{ block.settings.bgcolor }}";
    });

    {% if block.settings.position == "left" %}
      scrollBtn.style.left = "20px";
      scrollBtn.style.right = "auto";
    {% else %}
      scrollBtn.style.right = "20px";
      scrollBtn.style.left = "auto";
    {% endif %}

    {% if block.settings.shape == "square" %}
      scrollBtn.style.borderRadius = "10px";
    {% else %}
      scrollBtn.style.borderRadius = "50%";
    {% endif %}
  }

  /* -------- Scroll visibility + click behavior (all plans) -------- */
  window.addEventListener("scroll", () => {
    // Only animate if button is allowed to show by plan logic
    if (scrollBtn.style.display === "block" && window.scrollY > 100) {
      scrollBtn.classList.add("show");
    } else {
      scrollBtn.classList.remove("show");
    }
  });

  window.scrollToTop = function() {
    window.scrollTo({ top: 0, behavior: "smooth" });
  };
});
</script>

{% schema %}
{
  "name": "Scroll-2-Top",
  "target": "body",
  "settings": [
    {
      "type": "header",
      "content": "Plan Information",
      "info": "Customization options (colors, hover, icon style) work on Basic and Premium plans. Page-level visibility (product, collection, and pages) is available only for Premium plan users."
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Icon style",
      "options": [
        { "value": "chevron",        "label": "Chevron Up" },
        { "value": "arrow",          "label": "Arrow Up" },
        { "value": "triangle",       "label": "Triangle Up" },
        { "value": "double_chevron", "label": "Double Chevron Up" },
        { "value": "circle_arrow",   "label": "Arrow in Circle" },
        { "value": "minimal",        "label": "Minimal Caret Up" }
      ],
      "default": "chevron"
    },
    { "type": "color", "id": "bgcolor", "label": "Button Background Color", "default": "#28A745" },
    { "type": "color", "id": "hovercolor", "label": "Button Hover Color", "default": "#1C7530" },
    { "type": "color", "id": "iconcolor", "label": "Button Icon Color", "default": "#FFFFFF" },
    { "type": "checkbox", "id": "show_on_home_page", "label": "Show on Home Page", "default": true },
    { "type": "checkbox", "id": "show_on_product_page", "label": "Show on Product Page", "default": true },
    { "type": "checkbox", "id": "show_on_collection_page", "label": "Show on Collection Page", "default": true },
    { "type": "checkbox", "id": "show_on_pages", "label": "Show on Pages", "default": true },
    {
      "type": "select",
      "id": "shape",
      "label": "Button Shape",
      "options": [
        { "value": "circle", "label": "Circle" },
        { "value": "square", "label": "Square" }
      ],
      "default": "circle"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Button Position",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    }
  ]
}
{% endschema %}
